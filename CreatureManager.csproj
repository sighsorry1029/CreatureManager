    <ItemGroup>
        <PackageReference Include="ILRepack.Lib.MSBuild.Task" Version="2.0.44.1">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="YamlDotNet" Version="16.3.0" GeneratePathProperty="true" />
    </ItemGroup>
    <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets"/>
    <Target Name="GetAssemblyVersion" AfterTargets="ILRepacker"
            Condition="'$(DeployToValheim)' == 'true' Or '$(BuildPackages)' == 'true'">
        <GetAssemblyIdentity AssemblyFiles="$(TargetPath)">
            <Output TaskParameter="Assemblies" ItemName="Targets"/>
        </GetAssemblyIdentity>
        <ItemGroup>
            <AssemblyVersions Include="@(Targets->'%(Version)')"/>
        </ItemGroup>
        <Error Text="Failed to get Assembly Version." Condition="'%(AssemblyVersions.Identity)' == ''"/>
        <PropertyGroup>
            <AssemblyVersion>%(AssemblyVersions.Identity)</AssemblyVersion>
            <Major>$(AssemblyVersion.Split('.')[0])</Major>
            <Minor>$(AssemblyVersion.Split('.')[1])</Minor>
            <Patch>$(AssemblyVersion.Split('.')[2])</Patch>
            <PackageName>$(AssemblyName)_v$(Major).$(Minor).$(Patch)</PackageName>
            <PackageVersion>$(Major).$(Minor).$(Patch)</PackageVersion>
            <VersionString>$(Major).$(Minor).$(Patch)</VersionString>
        </PropertyGroup>
    </Target>
    <Target Name="CopyOutputDLL" AfterTargets="GetAssemblyVersion" Condition="'$(DeployToValheim)' == 'true'">
        <Error Text="DLL not found in target directory." Condition="!Exists('$(TargetDir)$(AssemblyName).dll')"/>
        <Error Text="DeployToValheim=true requires an existing CopyOutputDLLPath in environment.props or on the command line."
               Condition="'$(CopyOutputDLLPath)' == '' Or !Exists('$(CopyOutputDLLPath)')"/>
        <Copy SourceFiles="$(TargetDir)$(AssemblyName).dll" DestinationFolder="$(CopyOutputDLLPath)" OverwriteReadOnlyFiles="true"/>
        <Copy SourceFiles="$(TargetDir)$(AssemblyName).dll" DestinationFolder="$(CopyOutputDLLPath2)" OverwriteReadOnlyFiles="true" Condition="Exists('$(CopyOutputDLLPath2)')"/>
        <Copy SourceFiles="$(TargetDir)$(AssemblyName).dll" DestinationFolder="$(CopyOutputDLLPath3)" OverwriteReadOnlyFiles="true" Condition="Exists('$(CopyOutputDLLPath3)')"/>
    </Target>
    <Target Name="BuildReleasePackages" AfterTargets="GetAssemblyVersion"
            Condition="'$(BuildPackages)' == 'true' And '$(Configuration)|$(Platform)' == 'Release|AnyCPU'">
        <PropertyGroup>
            <PackageStagingRoot>$(BaseIntermediateOutputPath)package</PackageStagingRoot>
            <ThunderstoreStagingDir>$(PackageStagingRoot)\thunderstore\$(PackageName)</ThunderstoreStagingDir>
        </PropertyGroup>
        <Error Text="README.md not found in project directory." Condition="!Exists('$(ProjectDir)README.md')"/>
        <Error Text="CHANGELOG.md not found in Thunderstore directory." Condition="!Exists('$(ProjectDir)Thunderstore\CHANGELOG.md')"/>
        <Error Text="manifest.json not found in Thunderstore directory." Condition="!Exists('$(ProjectDir)Thunderstore\manifest.json')"/>
        <Error Text="icon.png not found in Thunderstore directory." Condition="!Exists('$(ProjectDir)Thunderstore\icon.png')"/>
        <Error Text="English translation not found in translations directory." Condition="!Exists('$(ProjectDir)translations\English.yml')"/>
        <PropertyGroup>
            <ThunderstoreManifestPath>$(ProjectDir)Thunderstore\manifest.json</ThunderstoreManifestPath>
            <ThunderstoreManifestText>$([System.IO.File]::ReadAllText('$(ThunderstoreManifestPath)'))</ThunderstoreManifestText>
            <ThunderstoreManifestVersionPattern>&quot;version_number&quot;\s*:\s*&quot;[^&quot;]*&quot;</ThunderstoreManifestVersionPattern>
            <ThunderstoreManifestVersionReplacement>&quot;version_number&quot;: &quot;$(PackageVersion)&quot;</ThunderstoreManifestVersionReplacement>
            <UpdatedThunderstoreManifestText>$([System.Text.RegularExpressions.Regex]::Replace('$(ThunderstoreManifestText)', '$(ThunderstoreManifestVersionPattern)', '$(ThunderstoreManifestVersionReplacement)'))</UpdatedThunderstoreManifestText>
        </PropertyGroup>
        <Error Text="Thunderstore manifest.json has no version_number string."
               Condition="$([System.Text.RegularExpressions.Regex]::IsMatch('$(ThunderstoreManifestText)', '$(ThunderstoreManifestVersionPattern)')) != 'True'"/>
        <WriteLinesToFile File="$(ThunderstoreManifestPath)" Lines="$(UpdatedThunderstoreManifestText)" Overwrite="true"/>
        <ReadLinesFromFile File="$(ProjectDir)Thunderstore\manifest.json">
            <Output TaskParameter="Lines" ItemName="ThunderstoreManifestLines"/>
        </ReadLinesFromFile>
        <PropertyGroup>
            <ThunderstoreManifestText>@(ThunderstoreManifestLines, ' ')</ThunderstoreManifestText>
        </PropertyGroup>
        <Error Text="Thunderstore manifest version_number must match assembly version $(PackageVersion)."
               Condition="$([System.Text.RegularExpressions.Regex]::IsMatch('$(ThunderstoreManifestText)', '&quot;version_number&quot;\s*:\s*&quot;$(PackageVersion)&quot;')) != 'True'"/>
        <RemoveDir Directories="$(PackageStagingRoot)" Condition="Exists('$(PackageStagingRoot)')"/>
        <MakeDir Directories="$(ThunderstoreStagingDir);$(ProjectDir)Thunderstore"/>
        <ItemGroup>
            <ThunderstorePackageFiles Include="$(TargetPath);$(ProjectDir)README.md;$(ProjectDir)Thunderstore\CHANGELOG.md;$(ProjectDir)Thunderstore\manifest.json;$(ProjectDir)Thunderstore\icon.png"/>
        </ItemGroup>
        <Copy SourceFiles="@(ThunderstorePackageFiles)" DestinationFolder="$(ThunderstoreStagingDir)"/>
        <Copy SourceFiles="$(ProjectDir)translations\English.yml" DestinationFiles="$(ThunderstoreStagingDir)\$(AssemblyName).English.yml"/>
        <ZipDirectory SourceDirectory="$(ThunderstoreStagingDir)" DestinationFile="$(ProjectDir)Thunderstore\$(PackageName).zip" Overwrite="true"/>
        <RemoveDir Directories="$(PackageStagingRoot)"/>
    </Target>

</Project>
